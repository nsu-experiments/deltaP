// =============================================================================
// manufacturing/populate.dp
// Generate synthetic manufacturing network data
// =============================================================================
//
// This script generates synthetic performance data for manufacturing routes.
// Run with: dp populate manufacturing
//
// Output: data/_synthetic/manufacturing.csv
//
// Based on probabilistic manufacturing analysis 
//
// =============================================================================

dpSem simulation;

// =============================================================================
// CONFIGURATION
// =============================================================================

r1 := 1; r2 := 2; r3 := 3;
baseline := 1;
carbon_strict := 2;
border_tight := 3;
combined := 4;


// =============================================================================
// DATA GENERATION
// =============================================================================

output("route,scenario,month,efficiency,service,sustainability");

// Route 1 - Baseline scenario (high performance)
for month in [1:12] do {
    eff := (month <= 8) & 1.0 | 0.0;      // 67% efficiency (8/12 months)
    svc := (month <= 8) & 1.0 | 0.0;      // 67% service
    sus := (month <= 7) & 1.0 | 0.0;      // 58% sustainability
    output("1,1,", month, ",", eff, ",", svc, ",", sus);
}

// Route 1 - Border tight scenario (degraded)
for month in [1:12] do {
    eff := (month <= 5) & 1.0 | 0.0;      // 42% efficiency
    svc := (month >= 2 & month <= 6) & 1.0 | 0.0;  // 42% service
    sus := (month <= 6) & 1.0 | 0.0;      // 50% sustainability
    output("1,3,", month, ",", eff, ",", svc, ",", sus);
}

// Route 2 - Baseline scenario (moderate performance)
for month in [1:12] do {
    eff := (month <= 5) & 1.0 | 0.0;      // 42% efficiency
    svc := (month <= 6) & 1.0 | 0.0;      // 50% service
    sus := (month <= 6) & 1.0 | 0.0;      // 50% sustainability
    output("2,1,", month, ",", eff, ",", svc, ",", sus);
}

// Route 2 - Border tight scenario (severely degraded)
for month in [1:12] do {
    eff := (month <= 3) & 1.0 | 0.0;      // 25% efficiency
    svc := (month <= 6) & 1.0 | 0.0;      // 50% service (maintains!)
    sus := (month <= 5) & 1.0 | 0.0;      // 42% sustainability
    output("2,3,", month, ",", eff, ",", svc, ",", sus);
}

// Route 3 - Baseline scenario (balanced, with resilience)
for month in [1:12] do {
    eff := (month <= 7) & 1.0 | 0.0;      // 58% efficiency
    svc := (month <= 7) & 1.0 | 0.0;      // 58% service
    sus := (month >= 2 & month <= 7) & 1.0 | 0.0;  // 50% sustainability
    output("3,1,", month, ",", eff, ",", svc, ",", sus);
}

// Route 3 - Border tight scenario (maintains performance!)
for month in [1:12] do {
    eff := (month <= 7) & 1.0 | 0.0;      // 58% efficiency (maintains!)
    svc := (month >= 2 & month <= 8) & 1.0 | 0.0;  // 58% service (maintains!)
    sus := (month >= 2 & month <= 7) & 1.0 | 0.0;  // 50% sustainability
    output("3,3,", month, ",", eff, ",", svc, ",", sus);
}
