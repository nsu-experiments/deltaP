) / 25.0;

sp avg_sustainability(country, scenario) := (
    meets_sustainability(2000, country, scenario) +
    meets_sustainability(2001, country, scenario) +
    meets_sustainability(2002, country, scenario) +
    meets_sustainability(2003, country, scenario) +
