output("");

// Brazil
brazil_eff := avg_efficiency(brazil, current_scenario);
brazil_svc := avg_service(brazil, current_scenario);
brazil_sus := avg_sustainability(brazil, current_scenario);
brazil_score := composite_score(brazil, current_scenario);

output("Brazil:");
output("  Efficiency:     ", brazil_eff);
output("  Service:        ", brazil_svc);
output("  Sustainability: ", brazil_sus);
output("  Composite:      ", brazil_score);
output("");

// Country comparison
if (usa_score > china_score & usa_score > germany_score & usa_score > india_score & usa_score > brazil_score) then {
    output("Recommendation: USA (highest composite score)");
}

if (china_score > usa_score & china_score > germany_score & china_score > india_score & china_score > brazil_score) then {
    output("Recommendation: China (highest composite score)");
}

if (germany_score > usa_score & germany_score > china_score & germany_score > india_score & germany_score > brazil_score) then {
    output("Recommendation: Germany (highest composite score)");
}

if (india_score > usa_score & india_score > china_score & india_score > germany_score & india_score > brazil_score) then {
    output("Recommendation: India (highest composite score)");
}

if (brazil_score > usa_score & brazil_score > china_score & brazil_score > germany_score & brazil_score > india_score) then {
    output("Recommendation: Brazil (highest composite score)");
}

output("");
output("=== CSV Output ===");
output("country,efficiency,service,sustainability,composite");
