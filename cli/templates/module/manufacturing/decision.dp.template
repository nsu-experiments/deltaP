output("2,", china_eff, ",", china_svc, ",", china_sus, ",", china_score);
output("3,", germany_eff, ",", germany_svc, ",", germany_sus, ",", germany_score);
output("4,", india_eff, ",", india_svc, ",", india_sus, ",", india_score);
output("5,", brazil_eff, ",", brazil_svc, ",", brazil_sus, ",", brazil_score);