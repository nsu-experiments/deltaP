dpSem decision;

// =============================================================================
// IMPORTS
// =============================================================================

// Configuration
// @import config;

// For now, manually include essentials:
r1 := 1; r2 := 2; r3 := 3;
Route := [r1:r3];

usa := 1;
china := 2;
germany := 3;
india := 4;
brazil := 5;
Country := [usa:brazil];


baseline := 1;
carbon_strict := 2;
border_tight := 3;
combined := 4;
Scenario := [baseline:combined];

Month := [1:12];


// =============================================================================
// DYNAMIC PREDICATES
// =============================================================================


Year := [2006:2020];

// Arguments must match database order: (year, country, govt_incentive)
dp meets_efficiency(year, country, govt_incentive) : 
    year in Year & country in Country & govt_incentive in [1:2];

dp meets_service(year, country, govt_incentive) :  
    year in Year & country in Country & govt_incentive in [1:2];

dp meets_sustainability(year, country, govt_incentive) : 
    year in Year & country in Country & govt_incentive in [1:2];

// =============================================================================
// PROBABILITY AGGREGATION
// =============================================================================

// =============================================================================
// PROBABILITY AGGREGATION
// =============================================================================

// Calculate average probability across time periods
sp avg_efficiency(country, scenario) := (
    meets_efficiency(2006, country, scenario) +
    meets_efficiency(2007, country, scenario) +
    meets_efficiency(2008, country, scenario) +
    meets_efficiency(2009, country, scenario) +
    meets_efficiency(2010, country, scenario) +
    meets_efficiency(2011, country, scenario) +
    meets_efficiency(2012, country, scenario) +
    meets_efficiency(2013, country, scenario) +
    meets_efficiency(2014, country, scenario) +
    meets_efficiency(2015, country, scenario) +
    meets_efficiency(2016, country, scenario) +
    meets_efficiency(2017, country, scenario) +
    meets_efficiency(2018, country, scenario) +
    meets_efficiency(2019, country, scenario) +
    meets_efficiency(2020, country, scenario)
) / 15.0;

sp avg_service(country, scenario) := (
    meets_service(2006, country, scenario) +
    meets_service(2007, country, scenario) +
    meets_service(2008, country, scenario) +
    meets_service(2009, country, scenario) +
    meets_service(2010, country, scenario) +
    meets_service(2011, country, scenario) +
    meets_service(2012, country, scenario) +
    meets_service(2013, country, scenario) +
    meets_service(2014, country, scenario) +
    meets_service(2015, country, scenario) +
    meets_service(2016, country, scenario) +
    meets_service(2017, country, scenario) +
    meets_service(2018, country, scenario) +
    meets_service(2019, country, scenario) +
    meets_service(2020, country, scenario)
) / 15.0;

sp avg_sustainability(country, scenario) := (
    meets_sustainability(2006, country, scenario) +
    meets_sustainability(2007, country, scenario) +
    meets_sustainability(2008, country, scenario) +
    meets_sustainability(2009, country, scenario) +
    meets_sustainability(2010, country, scenario) +
    meets_sustainability(2011, country, scenario) +
    meets_sustainability(2012, country, scenario) +
    meets_sustainability(2013, country, scenario) +
    meets_sustainability(2014, country, scenario) +
    meets_sustainability(2015, country, scenario) +
    meets_sustainability(2016, country, scenario) +
    meets_sustainability(2017, country, scenario) +
    meets_sustainability(2018, country, scenario) +
    meets_sustainability(2019, country, scenario) +
    meets_sustainability(2020, country, scenario)
) / 15.0;

// Composite score (geometric mean)
sp composite_score(country, scenario) := 
    avg_efficiency(country, scenario) * 
    avg_service(country, scenario) * 
    avg_sustainability(country, scenario);

// =============================================================================
// ANALYSIS
// =============================================================================

output("=== manufacturing Decision Analysis (Real Bioethanol Data) ===");
output("");

current_scenario := baseline;

output("Scenario: Baseline (Govt_Incentive=0)");
output("");

// USA
usa_eff := avg_efficiency(usa, current_scenario);
usa_svc := avg_service(usa, current_scenario);
usa_sus := avg_sustainability(usa, current_scenario);
usa_score := composite_score(usa, current_scenario);

output("USA:");
output("  Efficiency:     ", usa_eff);
output("  Service:        ", usa_svc);
output("  Sustainability: ", usa_sus);
output("  Composite:      ", usa_score);
output("");

