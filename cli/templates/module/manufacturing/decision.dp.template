// Configuration
// @import config;

// For now, manually include essentials:
r1 := 1; r2 := 2; r3 := 3;
Route := [r1:r3];

usa := 1;
china := 2;
germany := 3;
india := 4;
brazil := 5;
Country := [usa:brazil];


baseline := 1;
carbon_strict := 2;
border_tight := 3;
combined := 4;
Scenario := [baseline:combined];

Month := [1:12];


// =============================================================================
// DYNAMIC PREDICATES
// =============================================================================


Year := [2000:2024];


// Arguments must match database order: (year, country, govt_incentive)
dp meets_efficiency(year, country, govt_incentive) : 
    year in Year & country in Country & govt_incentive in [1:2];

dp meets_service(year, country, govt_incentive) :  
    year in Year & country in Country & govt_incentive in [1:2];

dp meets_sustainability(year, country, govt_incentive) : 
    year in Year & country in Country & govt_incentive in [1:2];

// =============================================================================
// PROBABILITY AGGREGATION
// =============================================================================

// =============================================================================
// PROBABILITY AGGREGATION
// =============================================================================

// Calculate average probability across time periods
sp avg_efficiency(country, scenario) := (
    meets_efficiency(2000, country, scenario) +
    meets_efficiency(2001, country, scenario) +
    meets_efficiency(2002, country, scenario) +
    meets_efficiency(2003, country, scenario) +
    meets_efficiency(2004, country, scenario) +
    meets_efficiency(2005, country, scenario) +
    meets_efficiency(2006, country, scenario) +
    meets_efficiency(2007, country, scenario) +
    meets_efficiency(2008, country, scenario) +
    meets_efficiency(2009, country, scenario) +
    meets_efficiency(2010, country, scenario) +
    meets_efficiency(2011, country, scenario) +
    meets_efficiency(2012, country, scenario) +
    meets_efficiency(2013, country, scenario) +
    meets_efficiency(2014, country, scenario) +
    meets_efficiency(2015, country, scenario) +
    meets_efficiency(2016, country, scenario) +
    meets_efficiency(2017, country, scenario) +
    meets_efficiency(2018, country, scenario) +
    meets_efficiency(2019, country, scenario) +
    meets_efficiency(2020, country, scenario) +
    meets_efficiency(2021, country, scenario) +
    meets_efficiency(2022, country, scenario) +
    meets_efficiency(2023, country, scenario) +
    meets_efficiency(2024, country, scenario)
) / 25.0;

