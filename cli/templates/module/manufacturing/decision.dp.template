    meets_sustainability(2008, country, scenario) +
    meets_sustainability(2009, country, scenario) +
    meets_sustainability(2010, country, scenario) +
    meets_sustainability(2011, country, scenario) +
    meets_sustainability(2012, country, scenario) +
    meets_sustainability(2013, country, scenario) +
    meets_sustainability(2014, country, scenario) +
    meets_sustainability(2015, country, scenario) +
    meets_sustainability(2016, country, scenario) +
